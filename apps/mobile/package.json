{
  "name": "@glitch/mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "dev": "EXPO_NO_REDIRECT_PAGE=1 dotenv -e ../../.env -- expo start --go",
    "dev:staging": "EXPO_NO_REDIRECT_PAGE=1 EXPO_PUBLIC_API_URL=https://glitch-api-staging.onrender.com EXPO_PUBLIC_SENTRY_ENVIRONMENT=staging dotenv -e ../../.env -- expo start --go",
    "dev:lan": "EXPO_NO_REDIRECT_PAGE=1 dotenv -e ../../.env -- expo start --lan --go",
    "start": "EXPO_NO_REDIRECT_PAGE=1 dotenv -e ../../.env -- expo start --go",
    "android": "EXPO_NO_REDIRECT_PAGE=1 dotenv -e ../../.env -- expo start --android --go",
    "ios": "EXPO_NO_REDIRECT_PAGE=1 dotenv -e ../../.env -- expo start --ios --go",
    "web": "dotenv -e ../../.env -- expo start --web",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@sentry/react-native": "~7.11.0",
    "country-state-city": "^3.2.1",
    "expo": "~55.0.9",
    "expo-apple-authentication": "^55.0.9",
    "expo-blur": "~55.0.10",
    "expo-crypto": "^55.0.10",
    "expo-dev-client": "~55.0.19",
    "expo-document-picker": "~55.0.9",
    "expo-image-manipulator": "~55.0.11",
    "expo-image-picker": "~55.0.14",
    "expo-secure-store": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "lucide-react-native": "^0.577.0",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-svg": "15.15.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  },
  "private": true
}
