{
  "name": "@glitch/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ENV_FILE=../../.env tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "test": "ENV_FILE=../../.env NODE_ENV=test OTP_PROVIDER=console APPLE_APP_BUNDLE_ID=com.glitch.finance pnpm db:migrate && ENV_FILE=../../.env NODE_ENV=test OTP_PROVIDER=console APPLE_APP_BUNDLE_ID=com.glitch.finance vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.3",
    "ioredis": "^5.8.1",
    "jose": "^6.2.1",
    "postgres": "^3.4.7",
    "prom-client": "^15.1.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "drizzle-kit": "^0.31.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
