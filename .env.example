# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
API_HOST=0.0.0.0

# Canonical public API origin used for generated asset URLs in hosted environments.
PUBLIC_API_BASE_URL=
# Writable directory for uploaded avatars. Defaults to the system temp directory when unset.
AVATAR_STORAGE_DIR=
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0
# Number of trusted proxy hops in front of the API. Keep 0 for local/dev.
TRUST_PROXY_HOPS=0
# Comma-separated allowed origins for CORS. Prefer explicit origins per environment.
MOBILE_APP_ORIGIN=http://localhost:8081,http://localhost:19006

# ─── Infrastructure ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://glitch:glitch@127.0.0.1:5432/glitch
REDIS_URL=redis://127.0.0.1:6379

# ─── Auth & OTP ──────────────────────────────────────────────────────────────
OTP_HASH_SECRET=change-me-in-production-otp-secret
OTP_PROVIDER=console
# Local-only debug convenience. Must remain false in staging/production.
DEBUG_OTP_EXPOSURE=true
# Must be a valid sender address in either plain or display-name form.
# For real delivery, this should use a verified Resend domain/sender identity.
OTP_EMAIL_FROM=Glitch Finance <noreply@example.com>
OTP_PROVIDER_REQUEST_TIMEOUT_MS=10000
RESEND_API_KEY=

AUTH_OTP_TTL_SECONDS=300
AUTH_MAX_OTP_ATTEMPTS=5
AUTH_MAX_ACTIVE_SESSIONS=5
AUTH_SESSION_TTL_DAYS=30
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_MAX_REQUEST_OTP=5
AUTH_RATE_LIMIT_MAX_VERIFY_OTP=10

# ─── Operational Endpoints & Alerts ──────────────────────────────────────────
STATUS_ENDPOINT_ENABLED=true
METRICS_ENDPOINT_ENABLED=true
ALERTS_WEBHOOK_URL=
ALERTS_COOLDOWN_SECONDS=60

SLO_MONITOR_ENABLED=false
SLO_MONITOR_WINDOW_SECONDS=300
SLO_MONITOR_EVALUATION_SECONDS=30
SLO_HTTP_5XX_RATE_THRESHOLD_PERCENT=2
SLO_HTTP_5XX_MIN_REQUESTS=100
SLO_OTP_DELIVERY_FAILURE_THRESHOLD=5

# ─── Product Defaults & Feature Flags ────────────────────────────────────────
SMS_IMPORT_SCAN_ENABLED=false
SMS_DISCLOSURE_VERSION=sms_disclosure_v1
APP_CURRENCY=INR

# OAuth providers (optional — Apple supported; Google remains disabled until nonce-safe flow is implemented)
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
APPLE_APP_BUNDLE_ID=

# ─── Mobile (Expo) ───────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1

# Google Sign-In — Web Client ID from Google Cloud Console
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_OAUTH_ENABLED=false
