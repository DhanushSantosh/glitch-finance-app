{
  "name": "glitch-finance-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "concurrently -n api,mobile -c cyan,magenta \"pnpm --filter @glitch/api dev\" \"pnpm --filter @glitch/mobile dev\"",
    "dev:android": "concurrently -n api,mobile -c cyan,magenta \"pnpm --filter @glitch/api dev\" \"pnpm android:fast\"",
    "dev:api": "pnpm --filter @glitch/api dev",
    "dev:mobile": "pnpm --filter @glitch/mobile dev",
    "android:fast": "bash ./scripts/android-fast.sh",
    "android:emulator": "bash ./scripts/android-fast.sh --emulator-only",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "db:logs": "docker compose -f infra/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
